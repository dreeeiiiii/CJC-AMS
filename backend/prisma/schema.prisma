// This is your consolidated Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // ⚠️ URL REMOVED: In Prisma 7, connection URLs are moved to prisma.config.ts
}

// --- Enums ---

enum Gender {
  Male
  Female
}

enum Role {
  MEMBER
  ADMIN
  VISITOR
}

enum Category {
  Invited
  WalkIn
}

// --- Models ---

model Member {
  id           Int      @id @default(autoincrement())
  firstName    String
  lastName     String
  middleName   String?  // Optional: mapped from 'middleInitial' in frontend
  contactNo    String
  address      String
  gender       Gender
  email        String   @unique
  password     String   // Required for login; Admin can set a default
  status       String   @default("New Member") 
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attendances  Attendance[]
}

model Visitor {
  id                Int          @id @default(autoincrement())
  firstName         String
  lastName          String
  middleName        String?
  contactNo         String?
  address           String?
  gender            Gender       @default(Male)
  email             String?      @unique
  
  // Updated fields to match frontend requirements
  category          Category     @default(WalkIn)
  churchAffiliation String?      // Mapped from 'originalChurch' in frontend
  invitedBy         String?      // Captures who invited the visitor
  
  role              Role         @default(VISITOR)
  visitedAt         DateTime     @default(now()) // Mapped from 'dateOfVisit'

  attendances       Attendance[]
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  message   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Verse {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  reference String
  topic     String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimony {
  id        Int      @id @default(autoincrement())
  name      String
  avatar    String?
  quote     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id         Int      @id @default(autoincrement())
  memberId   Int?     
  visitorId  Int?     
  recordedBy Int      // ID of the Admin who recorded the entry
  createdAt  DateTime @default(now())

  member     Member?  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  visitor    Visitor? @relation(fields: [visitorId], references: [id], onDelete: Cascade)
}