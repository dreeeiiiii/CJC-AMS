generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -------------------- ENUMS --------------------

enum Gender {
  Male
  Female
}

enum Role {
  MEMBER
  ADMIN
  VISITOR
}

enum Category {
  Invited
  WalkIn
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

// -------------------- MEMBER PROFILE (NO AUTH HERE) --------------------

model Member {
  id           Int      @id @default(autoincrement())

  firstName    String
  lastName     String
  middleName   String?
  email        String   @unique
  password     String
  role         Role     @default(MEMBER)
  contactNo    String
  address      String
  gender       Gender

  status       String   @default("New Member")
  category     String   @default("General")
  profileImage String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // relations
  account      UserAccount?  
  attendances  Attendance[]
  testimonies  Testimony?
}

// -------------------- AUTH SYSTEM --------------------

model UserAccount {
  id           Int      @id @default(autoincrement())

  email        String   @unique
  password     String

  role         Role     @default(MEMBER)
  status       AccountStatus @default(ACTIVE)

  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberId     Int      @unique
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// -------------------- VISITORS --------------------

model Visitor {
  id                Int      @id @default(autoincrement())

  firstName         String
  lastName          String
  middleName        String?

  contactNo         String?
  address           String?
  gender            Gender   @default(Male)
  email             String?
  category          Category @default(WalkIn)

  churchAffiliation String?
  invitedBy         String?
  purposeOfVisit    String?

  role              Role     @default(VISITOR)
  visitedAt         DateTime @default(now())

  attendances       Attendance[]
}

// -------------------- CONTENT --------------------

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  image     String?
  timestamp String
  category  String   @default("General")
  author    String   @default("CJCRSG Phils. Inc.")
  link      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Verse {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  reference String
  topic     String?
  isActive  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -------------------- TESTIMONY --------------------

model Testimony {
  id        Int      @id @default(autoincrement())
  quote     String   @db.Text
  status    String   @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberId  Int?     @unique
  member    Member?  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  name      String?
  avatar    String?
}

// -------------------- ATTENDANCE --------------------

model Attendance {
  id         Int      @id @default(autoincrement())

  memberId   Int?
  visitorId  Int?

  recordedBy Int

  createdAt  DateTime @default(now())

  member     Member?  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  visitor    Visitor? @relation(fields: [visitorId], references: [id], onDelete: Cascade)
}