// This is your consolidated Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // ⚠️ URL REMOVED: In Prisma 7, connection URLs are moved to prisma.config.ts
}

// --- Enums ---

enum Gender {
  Male
  Female
}

enum Role {
  MEMBER
  ADMIN
  VISITOR
}

enum Category {
  Invited
  WalkIn
}

// --- Models ---

model Member {
  id           Int          @id @default(autoincrement())
  firstName    String
  lastName     String
  middleName   String?      
  contactNo    String
  address      String
  gender       Gender
  email        String       @unique
  password     String       
  status       String       @default("New Member") 
  role         Role         @default(MEMBER)
  profileImage String?      
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  attendances  Attendance[]
  
  // 🚀 Add this line to link a member to their testimonies
  testimonies  Testimony[]
}

model Visitor {
  id                Int          @id @default(autoincrement())
  firstName         String
  lastName          String
  middleName        String?
  contactNo         String?
  address           String?
  gender            Gender       @default(Male)
  email             String?      @unique
  
  // Updated fields to match frontend requirements
  category          Category     @default(WalkIn)
  churchAffiliation String?      // Mapped from 'originalChurch' in frontend
  invitedBy         String?      // Captures who invited the visitor
  
  role              Role         @default(VISITOR)
  visitedAt         DateTime     @default(now()) // Mapped from 'dateOfVisit'

  attendances       Attendance[]
}

model Announcement {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text  // 🚀 Changed from message to content to match your frontend textareas
  image     String?            // 🚀 Added to store your uploaded Multer image paths
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Verse {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  reference String
  topic     String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimony {
  id        Int      @id @default(autoincrement())
  quote     String   @db.Text
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberId  Int?
  member    Member?  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  name      String?
  avatar    String?
}

model Attendance {
  id         Int      @id @default(autoincrement())
  memberId   Int?     
  visitorId  Int?     
  recordedBy Int      // ID of the Admin who recorded the entry
  createdAt  DateTime @default(now())

  member     Member?  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  visitor    Visitor? @relation(fields: [visitorId], references: [id], onDelete: Cascade)
}