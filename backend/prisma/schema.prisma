// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url is handled in your prisma.config.ts for Prisma 7
}

enum Gender {
  Male
  Female
}

enum Role {
  MEMBER
  ADMIN
  VISITOR
}

enum Category {
  Invited
  WalkIn
}

model Member {
  id        Int      @id @default(autoincrement())
  fullName  String
  contactNo String
  address   String
  gender    Gender
  email     String   @unique
  password  String
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visitor {
  id                Int      @id @default(autoincrement())
  fullName          String
  contactNo         String?
  address           String?
  gender            Gender
  email             String?  @unique
  category          Category @default(WalkIn)
  churchAffiliation String?  // Added for Visitor identification
  role              Role     @default(VISITOR) 
  visitedAt         DateTime @default(now())
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  message   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}